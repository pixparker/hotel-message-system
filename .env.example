# Copy to .env and fill in. .env is gitignored.
# Validation: packages/shared/src/env.ts (api + worker refuse to start on invalid input).
# Rotate production secrets via the platform secret store, never from this file.
# See docs/runbook/secrets-rotation.md for how.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgres://hms:hms@localhost:5432/hms

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) ---
# Generate each with: openssl rand -base64 48
# Must be >= 32 chars. In production they MUST differ.
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-base64-48-output
JWT_REFRESH_SECRET=replace-me-with-a-different-openssl-rand-base64-48-output
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- API ---
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:5173

# --- WhatsApp driver ---
# mock | cloud | baileys  (task 6: real cloud impl)
WA_PROVIDER=mock
# Required when WA_PROVIDER=cloud:
WA_CLOUD_ACCESS_TOKEN=
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_VERIFY_TOKEN=

# --- Email (Task 3: verification + password reset) ---
# If RESEND_API_KEY is set, uses Resend (https://resend.com).
# If omitted, logs tokens to console (dev mode).
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# --- Bootstrap (dev seed only; will be removed at task 11 when signup lands) ---
BOOTSTRAP_ORG_NAME=Reform Hotel
BOOTSTRAP_ADMIN_EMAIL=admin@hotel.local
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- Web (Vite) ---
# Set VITE_DEMO=1 for the public no-backend demo build (used by vercel.json).
# VITE_API_URL=https://api.example.com
