# Shared-infra env. Lives at /srv/infra/.env on the server.
# Generate strong values before first `docker compose up`.

# Caddy / TLS
ACME_EMAIL=admin@clientora.net

# Postgres admin credentials (the superuser that clientora uses to create per-MVP DBs/roles)
POSTGRES_ADMIN_USER=clientora_admin
POSTGRES_ADMIN_PASSWORD=generate-with-openssl-rand-base64-32
