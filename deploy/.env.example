# Production env (docker-compose.yml reads this via `env_file: .env`).
SITE_DOMAIN=msg.hotel.local

POSTGRES_USER=hms
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hms

JWT_ACCESS_SECRET=replace-with-32-random-bytes
